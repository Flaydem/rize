<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - Page introuvable</title>
  <style>
    body { background: #0a0a0a; color: #fff; font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
    .container { text-align: center; }
    h1 { font-size: 4rem; font-weight: 900; margin: 0; }
    h1 span { color: #e11d48; }
    p { color: #6b7280; margin-top: 0.5rem; }
    a { color: #e11d48; text-decoration: none; font-weight: 600; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <h1><span>404</span></h1>
    <p>Page introuvable</p>
    <a href="/">Retour a l'accueil</a>
  </div>
</body>
</html>
